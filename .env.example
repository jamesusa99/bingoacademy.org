# Copy to .env.local for local dev, and add the same keys in your host (e.g. Vercel → Settings → Environment Variables).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth (Supabase Dashboard):
# - Authentication → Providers → Email: enable
# - Authentication → Providers → Google:
#     1. Enable Google
#     2. Create OAuth credentials in Google Cloud Console → APIs & Services → Credentials
#        → OAuth 2.0 Client ID → Web application
#     3. Authorized JavaScript origins: http://localhost:5173 and https://www.bingoacademy.org
#     4. Authorized redirect URIs: https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
#        (copy exact URL from Supabase → Authentication → Providers → Google → Callback URL)
#     5. Paste Client ID + Client Secret into Supabase Google provider settings → Save
# - Authentication → URL Configuration → Redirect URLs: add
#     http://localhost:5173/auth/callback
#     http://localhost:5173/reset-password
#     and the same paths on your production origin
# - Site URL: http://localhost:5173 (or production origin, must match where users request the reset)
# - Authentication → Email Templates → Reset password: use a direct token_hash link (works in any browser):
#     <a href="{{ .SiteURL }}/reset-password?token_hash={{ .TokenHash }}&type=recovery">Reset password</a>

# Admin bootstrap (comma-separated emails until profiles.role is set)
VITE_ADMIN_EMAILS=you@bingoacademy.org

# AI Jailbreak Adventure — server only (never VITE_*)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Server API (local npm run dev + Vercel api/server.js) — never expose service role to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Tip: SUPABASE_URL can match VITE_SUPABASE_URL. On Vercel, add SUPABASE_* (and VITE_*) in Project → Environment Variables, then redeploy.

# Optional: server-to-server admin calls
ADMIN_API_SECRET=
ADMIN_EMAILS=

# Stripe (API server — Checkout + webhooks) — NOT VITE_*
# If www.bingoacademy.org is on Vercel, add these in Vercel → Environment Variables (not only Railway).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Public site URL for Checkout success/cancel redirects (production)
SITE_URL=https://www.bingoacademy.org
# Allow DELETE /api/me/enrollments + Profile reset UI on production (or use /profile?debug=1)
ALLOW_ENROLLMENT_RESET=false
VITE_ALLOW_ENROLLMENT_RESET=false

# Cloudflare Stream (API server — upload + sync playback URLs)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional fallback if API omits playback URLs (Stream dashboard → Customer subdomain)
# Use ONLY the id part, e.g. uoz4rj725ijgv17s — NOT the full customer-xxx.cloudflarestream.com URL
CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Optional: signed Cloudflare Stream playback (POST /api/video/token)
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY=
# Client manifest URLs (optional; match CLOUDFLARE_STREAM_CUSTOMER_CODE)
VITE_CLOUDFLARE_STREAM_CUSTOMER_CODE=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
# Max video duration for direct uploads (seconds). Cloudflare caps at 36000 (10 hours).
STREAM_MAX_DURATION_SECONDS=36000
