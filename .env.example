# Copy to .env.local for local dev, and add the same keys in your host (e.g. Vercel → Settings → Environment Variables).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth (Supabase Dashboard):
# - Authentication → Providers → Email: enable
# - Authentication → Providers → Google: enable + Client ID/Secret from Google Cloud Console
# - Authentication → URL Configuration → Redirect URLs: add http://localhost:5173/auth/callback and your production URL
# - Site URL: http://localhost:5173 (or production origin)

# Admin bootstrap (comma-separated emails until profiles.role is set)
VITE_ADMIN_EMAILS=you@bingoacademy.org

# AI Jailbreak Adventure — server only (never VITE_*)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Server API (local npm run dev + Vercel api/server.js) — never expose service role to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Tip: SUPABASE_URL can match VITE_SUPABASE_URL. On Vercel, add SUPABASE_* (and VITE_*) in Project → Environment Variables, then redeploy.

# Optional: server-to-server admin calls
ADMIN_API_SECRET=
ADMIN_EMAILS=

# Stripe (Railway)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare Stream (API server — upload + sync playback URLs)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional fallback if API omits playback URLs (find in Stream dashboard → Customer subdomain)
CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Optional webhook auth header value for POST /api/webhooks/cloudflare-stream
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
