# Copy to .env.local for local dev, and add the same keys in your host (e.g. Vercel → Settings → Environment Variables).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth (Supabase Dashboard):
# - Authentication → Providers → Email: enable
# - Authentication → Providers → Google: enable + Client ID/Secret from Google Cloud Console
# - Authentication → URL Configuration → Redirect URLs: add http://localhost:5173/auth/callback and your production URL
# - Site URL: http://localhost:5173 (or production origin)

# Admin bootstrap (comma-separated emails until profiles.role is set)
VITE_ADMIN_EMAILS=you@bingoacademy.org

# AI Jailbreak Adventure — server only (never VITE_*)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Supabase service role — Railway / server only (never VITE_*)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: server-to-server admin calls
ADMIN_API_SECRET=
ADMIN_EMAILS=

# Stripe (Railway)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare Stream (Railway)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
